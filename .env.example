# Server
PORT=3000
NODE_ENV=development

# MongoDB (leave empty for in-memory fallback in dev)
MONGODB_URI=

# Redis / Upstash (leave empty for in-memory fallback in dev)
REDIS_URL=

# Auth
JWT_SECRET=change-this-to-a-random-secret-in-production

# Admin
ADMIN_SECRET=admin-secret-change-me

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=*
